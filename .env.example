# ---- Forms (Next.js API routes + Resend) ----
# Add these in Vercel → Settings → Environment Variables (never commit real keys).
# https://resend.com/docs/dashboard/api-keys
RESEND_API_KEY=re_xxxxxxxx
# Must use a domain you verified in Resend (Domains), e.g.:
# RESEND_FROM="brain & co. <hello@yourdomain.com>"
RESEND_FROM=

# Optional: override inboxes (defaults: contact@brainnco.com and newsletter@brainnco.com)
# RESEND_CONTACT_TO=contact@brainnco.com
# RESEND_NEWSLETTER_TO=newsletter@brainnco.com

# Optional: submit forms via Web3Forms in the browser (skip API routes)
# NEXT_PUBLIC_USE_WEB3FORMS=true
# NEXT_PUBLIC_WEB3FORMS_CONTACT_ACCESS_KEY=
# NEXT_PUBLIC_WEB3FORMS_NEWSLETTER_ACCESS_KEY=

# ---- WhatsApp floating button ----
# Number with country code, no + or leading 0 (e.g. 966554231498)
NEXT_PUBLIC_WHATSAPP_NUMBER=966554231498
