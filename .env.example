# ---- Forms (Next.js API routes + Resend) ----
# One API key for both routes. Add in Vercel → Settings → Environment Variables (never commit real keys).
# https://resend.com/docs/dashboard/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Resend "from" for contact form (verified domain), e.g. "brain & co. <contact@brainnco.com>"
# Delivers to contact@brainnco.com; Reply-To is the person who submitted the form.
RESEND_CONTACT_FROM=

# Resend "from" for newsletter form (verified domain), e.g. "brain & co. <newsletter@brainnco.com>"
# Delivers to newsletter@brainnco.com; Reply-To is the subscriber.
RESEND_NEWSLETTER_FROM=

# Optional: submit forms via Web3Forms in the browser (skip API routes)
# NEXT_PUBLIC_USE_WEB3FORMS=true
# NEXT_PUBLIC_WEB3FORMS_CONTACT_ACCESS_KEY=
# NEXT_PUBLIC_WEB3FORMS_NEWSLETTER_ACCESS_KEY=

# ---- WhatsApp floating button ----
NEXT_PUBLIC_WHATSAPP_NUMBER=966554231498
