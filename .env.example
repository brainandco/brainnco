# ---- Forms (Next.js API routes + Resend) ----
# One API key for both routes. Vercel → Settings → Environment Variables (never commit real keys).
# https://resend.com/docs/dashboard/api-keys
RESEND_API_KEY=re_xxxxxxxx

# Verified mailbox only (inside <> in the From header). The visible From *name* is the person submitting the form.
# Example value: contact@brainnco.com
RESEND_CONTACT_FROM=

# Same for newsletter: verified mailbox; visible From name = subscriber’s email.
# Example value: newsletter@brainnco.com
RESEND_NEWSLETTER_FROM=

# Optional: Web3Forms in the browser (skip API routes)
# NEXT_PUBLIC_USE_WEB3FORMS=true
# NEXT_PUBLIC_WEB3FORMS_CONTACT_ACCESS_KEY=
# NEXT_PUBLIC_WEB3FORMS_NEWSLETTER_ACCESS_KEY=

# ---- WhatsApp ----
NEXT_PUBLIC_WHATSAPP_NUMBER=966554231498
